# Development Environment Configuration
# =====================================

# Application Environment
NODE_ENV=development
ENVIRONMENT=development

# Database Configuration
POSTGRES_PASSWORD=dev_password_123
POSTGRES_DB=cv_database
POSTGRES_USER=cv_user

# Qdrant Configuration - Development Optimized
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_MAX_CONNECTIONS=10

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Authentication
# Admin bootstrap (used only if the admin user does not exist yet)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# JWT signing secret
JWT_SECRET_KEY=dev_jwt_secret_key_123
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Candidate Tracker (isolated Postgres tables)
# Keep this OFF by default in production until staging verified.
ENABLE_CANDIDATE_TRACKER=false
# Separate DB from auth DB. Example (dev): use postgres-dev from docker-compose.dev.yml (port 5434 on host).
# TRACKER_DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5434/cv_analyzer_dev
TRACKER_DB_URL=
# Safety hints: comma-separated substrings treated as "production"; dev will refuse to connect unless overridden.
# Example: TRACKER_PROD_URL_HINTS=rds.amazonaws.com,alphadatarecruitment.ae
TRACKER_PROD_URL_HINTS=
ALLOW_PROD_DATA_ACCESS=false

# Rate Limiting - Development Values
MAX_GLOBAL_CONCURRENT=50
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_RECOVERY_TIME=300

# Job Queue Configuration - Development Optimized
MIN_QUEUE_WORKERS=2
MAX_QUEUE_WORKERS=20
MEMORY_THRESHOLD_MB=4096
CPU_THRESHOLD_PERCENT=90
QUEUE_SIZE_THRESHOLD=1000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE=http://localhost:3000/api
BACKEND_URL=http://localhost:8000

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=false
LOG_LEVEL=DEBUG
ENABLE_REQUEST_LOGGING=true

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
SECURE_COOKIES=false
TRUSTED_PROXY=false

# Redis Configuration (Development)
# Use local redis in docker-compose.dev.yml by default:
#   REDIS_HOST=redis-dev
#   REDIS_PORT=6379
# If you use Redis Cloud instead, set these to your own values (DO NOT COMMIT real credentials):
REDIS_HOST=redis-dev
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_DB=0
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# --- Login OTP via Microsoft Graph (production / real email) ---
# docker-compose.cpu.yml loads ./.env for the backend. These do NOT change any stored CV/Qdrant data.
#
# Real OTP (default): leave OTP_DISABLE_EMAIL unset or set to false/0.
# Dev shortcut: OTP_DISABLE_EMAIL=1 skips Graph and uses OTP_FIXED_CODE (never use in production).
OTP_DISABLE_EMAIL=false
OTP_FIXED_CODE=123456
#
# App registration (client credentials) with Mail.Send application permission + admin consent.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
#
# Mailbox that sends OTP (must exist in Microsoft 365; Graph URL uses this user id).
OTP_FROM_EMAIL=cv@alphadatarecruitment.ae
OTP_FROM_NAME=Alpha CV System
