############################
# Frontend (Next.js) build context ignores
# Safe for production too: reduces context, avoids leaking secrets/data
############################

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts
.next/
out/
dist/

# Logs
*.log

# Cache / tooling
.eslintcache
tsconfig.tsbuildinfo

# Testing
coverage/

# Local environment files (do not send to Docker build context)
.env
.env.*
.env.local
.env.*.local

# Local storage / runtime artifacts (large, not needed for image build)
storage/
uploads/
upload/
media/
data/
backups/
tmp/
*.sqlite
*.db

# Git / IDE
.git/
.gitignore
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
